{
  "name": "h3-trust",
  "private": true,
  "version": "0.1.0",
  "description": "H3 Trust — Trust Investigation Platform (OmegaClaw Harness)",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @h3-trust/server --filter @h3-trust/harness dev",
    "dev:harness": "pnpm --filter @h3-trust/harness dev",
    "dev:server": "pnpm --filter @h3-trust/server dev",
    "build": "pnpm -r build",
    "seed": "pnpm --filter @h3-trust/server seed",
    "fixtures:write": "pnpm --filter @h3-trust/server fixtures:write",
    "fixtures:load": "pnpm --filter @h3-trust/server fixtures:load",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.2"
  }
}
